  "cases": [
    {
      "case_id": "plain-text",
      "payload_kind": "utf8",
      "content": "PLAIN-MARKER-11 plain text ingestion evidence.",
      "media_type": "text/plain",
      "expected_markers": ["PLAIN-MARKER-11"],
      "expected_status": "parsed",
      "expected_detail": "parsed",
      "expected_contains": "PLAIN-MARKER-11",
      "minimum_blocks": 1
    },
    {
      "case_id": "markdown",
      "payload_kind": "utf8",
      "content": "# MARKDOWN-MARKER-22\n\nA paragraph with **evidence**.",
