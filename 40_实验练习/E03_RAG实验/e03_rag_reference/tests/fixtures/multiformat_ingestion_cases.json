      "media_type": "text/html; charset=utf-8",
      "expected_markers": ["HTML-MARKER-33"],
      "expected_status": "parsed",
      "expected_detail": "parsed",
      "expected_contains": "HTML-MARKER-33",
      "expected_not_contains": "DO-NOT-EXTRACT-991",
      "minimum_tables": 1,
      "minimum_rows": 2,
      "minimum_cells": 4
    },
    {
      "case_id": "csv-table",
